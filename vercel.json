{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/register",
      "methods": ["POST", "OPTIONS"],
      "dest": "api/index.js"
    },
    {
      "src": "/login",
      "methods": ["POST", "OPTIONS"],
      "dest": "api/index.js"
    }
  ]
}
